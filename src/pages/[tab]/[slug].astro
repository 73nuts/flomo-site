---
import Base from '~/layouts/Base.astro';
import ReaderNav from '~/components/islands/ReaderNav.svelte';
import EndMark from '~/components/islands/EndMark.svelte';
import DesktopSidebar from '~/components/DesktopSidebar.astro';
import { TABS, TAB_BY_ID, type TabId } from '~/lib/tabs';
import { fmtDate } from '~/lib/date';
import { url } from '~/lib/url';
import { getCollection, render, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const all = await getCollection('memos');
  return TABS.flatMap((t) => {
    const sorted = all
      .filter((m) => m.data.tab === t.id)
      .sort((a, b) => (a.data.date < b.data.date ? 1 : -1));
    return sorted.map((m, i) => ({
      params: { tab: t.id, slug: m.data.id },
      props: {
        entry: m,
        prev: sorted[i - 1]?.data.id ?? null,
        next: sorted[i + 1]?.data.id ?? null,
        total: sorted.length,
        idx: i + 1,
      },
    }));
  });
}

type Props = {
  entry: CollectionEntry<'memos'>;
  prev: string | null;
  next: string | null;
  total: number;
  idx: number;
};

const { tab: tabParam } = Astro.params as { tab: TabId };
const tab = TAB_BY_ID[tabParam];
const { entry, prev, next, total, idx } = Astro.props as Props;

const { Content } = await render(entry);

const pageTitle = entry.data.title
  ? `${entry.data.title} · ${tab.name}`
  : `${entry.data.date} · ${tab.name}`;
const prevHref = prev ? url(`${tabParam}/${prev}`) : null;
const nextHref = next ? url(`${tabParam}/${next}`) : null;
const closeHref = url(tabParam);
---

<Base title={pageTitle} accent={tab.accent} accentRgb={tab.accentRgb}>
  <DesktopSidebar currentTab={tabParam} />
  <main class="screen has-sidebar" transition:name="screen" transition:animate="slide">
    <header class="topbar">
      <a class="back" href={closeHref}>返回</a>
      <h1 class="title">{tab.name}</h1>
      <span class="cnt">
        {String(idx).padStart(2, '0')} / {String(total).padStart(2, '0')}
      </span>
    </header>

    <section class="reading">
      <article class="paper">
        <div class="meta">
          <span class="ts">{fmtDate(entry.data.date)}</span>
          {entry.data.from && <span class="from-inline">{entry.data.from}</span>}
        </div>
        {entry.data.title && <h1 class="essay-title">{entry.data.title}</h1>}
        <div class="divider"></div>
        <div class="body">
          <Content />
        </div>
        {entry.data.from && <div class="from-bottom">— {entry.data.from}</div>}
        <EndMark client:load />
        <span class="fold"></span>
      </article>

      <ReaderNav client:load {prevHref} {nextHref} {closeHref} />
    </section>
  </main>
</Base>

<style>
  .from-inline {
    font-family: var(--sans);
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--muted);
    text-align: right;
    max-width: 60%;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .from-bottom {
    margin-top: 28px;
    font-family: var(--serif);
    font-style: italic;
    font-size: 13px;
    color: var(--muted);
    text-align: right;
    letter-spacing: 0.05em;
  }
  .essay-title {
    font-family: var(--brush);
    font-size: 24px;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--ink);
    margin: 6px 0 0;
    line-height: 1.5;
  }
</style>
