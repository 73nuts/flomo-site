---
import type { Tab } from '~/lib/tabs';
import { url } from '~/lib/url';

interface Props {
  tab: Tab;
  count: number;
}

const { tab, count } = Astro.props;
---

<a
  class="tab-card"
  href={url(tab.id)}
  style={`--accent: ${tab.accent}; --accent-rgb: ${tab.accentRgb};`}
>
  <span class="tape"></span>
  <div class="title">{tab.name}</div>
  <div class="sub">
    {count} · {tab.subtitle}
  </div>
  <span class="motif"></span>
</a>

<style>
  .tab-card {
    position: relative;
    aspect-ratio: 1 / 1;
    background: var(--bg-paper);
    border-radius: var(--radius);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05), 0 8px 24px rgba(0, 0, 0, 0.06);
    padding: 18px 18px 14px;
    transition: transform var(--dur-med) var(--ease), box-shadow var(--dur-med) var(--ease);
    cursor: pointer;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    color: var(--ink);
  }
  .tab-card:hover {
    transform: translateY(-4px) rotate(0deg) !important;
    box-shadow: 0 6px 14px rgba(0, 0, 0, 0.1), 0 14px 36px rgba(0, 0, 0, 0.08);
  }
  .tape {
    position: absolute;
    top: -7px;
    left: 50%;
    width: 42px;
    height: 14px;
    transform: translateX(-50%) rotate(-3deg);
    background: rgba(var(--accent-rgb), 0.35);
    border-left: 1px dashed rgba(0, 0, 0, 0.05);
    border-right: 1px dashed rgba(0, 0, 0, 0.05);
  }
  .title {
    font-family: var(--brush);
    font-size: 17px;
    font-weight: 500;
    letter-spacing: 0.1em;
    line-height: 1.4;
    margin-bottom: 6px;
  }
  .sub {
    font-family: var(--sans);
    font-size: 10px;
    color: var(--muted);
    letter-spacing: 0.12em;
    margin-top: auto;
  }
  .motif {
    position: absolute;
    right: 14px;
    bottom: 14px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(var(--accent-rgb), 0.7);
  }
</style>
