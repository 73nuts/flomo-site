---
import { fmtDate } from '~/lib/date';
import { url } from '~/lib/url';
import MemoBody from './MemoBody.astro';
import LongMemo from './islands/LongMemo.svelte';

interface Props {
  tabId: string;
  id: string;
  date: string;
  body: string;
  /** 右上角归属（作者 / 书名）—— 仅读书笔记渲染。其他 tab 不渲染。 */
  from?: string;
  title?: string;
}

const { tabId, id, date, body, from, title } = Astro.props;
const href = url(`${tabId}/${id}`);
const isLong = body.length > 200 || !!title;
---

<a class="card" href={href}>
  <div class="meta">
    <span class="ts">{fmtDate(date)}</span>
    {from && <span class="from-inline">{from}</span>}
  </div>
  {title && <h2 class="card-title">{title}</h2>}
  {
    isLong ? (
      <LongMemo client:idle>
        <MemoBody body={body} />
      </LongMemo>
    ) : (
      <MemoBody body={body} />
    )
  }
  <span class="fold-corner"></span>
</a>

<style>
  .card { color: var(--ink); }
  .meta {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 10px;
  }
  .from-inline {
    font-family: var(--sans);
    font-size: 10.5px;
    letter-spacing: 0.05em;
    color: var(--muted);
    text-align: right;
    max-width: 55%;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .card-title {
    font-family: var(--brush);
    font-size: 18px;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--ink);
    margin: 4px 0 10px;
    line-height: 1.5;
  }
</style>
