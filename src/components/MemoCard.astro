---
import { fmtDate } from '~/lib/date';
import { url } from '~/lib/url';
import MemoBody from './MemoBody.astro';
import LongMemo from './islands/LongMemo.svelte';

interface Props {
  tabId: string;
  id: string;
  date: string;
  body: string;
  tags: string[];
  title?: string;
}

const { tabId, id, date, body, tags, title } = Astro.props;
const href = url(`${tabId}/${id}`);
// 长文阈值：中英混合按字符数 200 粗略估计
const isLong = body.length > 200 || !!title;
---

<a class="card" href={href}>
  <div class="meta">
    <span class="ts">{fmtDate(date)}</span>
    {
      tags.length > 0 && (
        <span class="tags">
          {tags.map((t) => (
            <span class="tag">{t}</span>
          ))}
        </span>
      )
    }
  </div>
  {title && <h2 class="card-title">{title}</h2>}
  {
    isLong ? (
      <LongMemo client:idle>
        <MemoBody body={body} />
      </LongMemo>
    ) : (
      <MemoBody body={body} />
    )
  }
  <span class="fold-corner"></span>
</a>

<style>
  .card { color: var(--ink); }
  .meta {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 10px;
  }
  .tags {
    display: flex;
    gap: 5px;
    flex-wrap: wrap;
  }
  .card-title {
    font-family: var(--brush);
    font-size: 18px;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--ink);
    margin: 4px 0 10px;
    line-height: 1.5;
  }
</style>
