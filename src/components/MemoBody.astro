---
/**
 * 列表页的 memo 正文预览。按空行切段，`- ` 前缀识别列表，
 * 粗略去掉 markdown 标题前缀（`#+ `）避免预览里出现裸井号。
 * 阅读页（[slug].astro）走 Astro 原生 render() 做完整 markdown 渲染。
 */
interface Props {
  body: string;
  class?: string;
}

const { body, class: cls = 'memo-body' } = Astro.props;

const trimmed = body.trim();
const lines = trimmed.split('\n');
const allListItems = lines.every((l) => l.trim().startsWith('- ') || l.trim() === '');
const isList = lines.some((l) => l.trim().startsWith('- ')) && allListItems;

function stripMdMarks(s: string): string {
  return s
    .replace(/^#{1,6}\s+/gm, '') // 标题前缀
    .replace(/^>\s+/gm, '')       // 引用前缀
    .replace(/\*\*([^*]+)\*\*/g, '$1') // 粗体
    .replace(/\*([^*]+)\*/g, '$1');    // 斜体
}
---

{
  isList ? (
    <div class={cls}>
      <ul>
        {lines
          .map((l) => l.trim())
          .filter((l) => l.startsWith('- '))
          .map((l) => <li>{stripMdMarks(l.slice(2))}</li>)}
      </ul>
    </div>
  ) : (
    <div class={cls}>
      {trimmed.split(/\n\s*\n/).map((p) => (
        <p>{stripMdMarks(p)}</p>
      ))}
    </div>
  )
}
