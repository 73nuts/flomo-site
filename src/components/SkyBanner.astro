---
/**
 * 顶部一笔天色。根据访问时设备本地小时切换 morning / afternoon / dusk / night。
 *
 * 为什么不是 svelte 岛屿：
 *   之前用 <SkyBanner client:only="svelte" /> 在 mobile Chrome 下出现了 .sky 宽度
 *   被 astro-island 包装元素限制的 bug（只渲染左半屏，右侧留白）。
 *   改用 Astro 组件 + is:inline 脚本：div 在服务端就渲染，
 *   客户端只负责根据当前时间更新 class，定位不受任何包装层影响。
 */
import { skyFromHour } from '~/lib/sky';

// 服务端静态渲染取不到访客的时间；先用 afternoon 兜底，客户端立即覆盖。
const initial = skyFromHour(new Date().getHours());
---

<div id="sky" class={`sky ${initial}`}></div>

<script is:inline>
  (function () {
    function mood(h) {
      if (h < 5) return 'midnight';
      if (h < 6) return 'night';
      if (h < 11) return 'morning';
      if (h < 16) return 'afternoon';
      if (h < 20) return 'dusk';
      return 'night';
    }
    function apply() {
      var el = document.getElementById('sky');
      if (!el) return;
      el.className = 'sky ' + mood(new Date().getHours());
    }
    function fadeIn() {
      var el = document.getElementById('sky');
      if (el) requestAnimationFrame(function () { el.classList.add('on'); });
    }
    apply();
    fadeIn();
    setInterval(apply, 60 * 1000);
    // Astro 视图过渡切页后重新挂元素，需要再 apply 一次
    document.addEventListener('astro:page-load', function () { apply(); fadeIn(); });
  })();
</script>

<style is:global>
  /* sky = "晨光透窗"。来自 v2-good-taste 设计稿 mobile-delights 的 radial 双光斑构造：
     时段配色（linear gradient 底层）保留原稿 4 段高饱和色相 + 顶部叠两团光斑，
     让纯色带升级为"有方向的光"。opacity 0→1 淡入也来自原稿 .sky.on 切换。 */
  #sky {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 320px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.6s cubic-bezier(0.2, 0.6, 0.2, 1), background 0.8s ease;
    z-index: 0;
  }
  #sky.on { opacity: 1; }
  /* 底部柔和淡出到页面底色，让 sky 和内容无缝衔接 */
  #sky::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 96px;
    background: linear-gradient(to bottom, transparent, var(--bg-page));
    pointer-events: none;
  }
  /* 晨光：右上一团暖橙光斑 + 左上一团粉光，底层暖橙渐变 */
  #sky.morning {
    background:
      radial-gradient(ellipse 90% 70% at 70% 0%, rgba(255, 200, 140, 0.55), transparent 65%),
      radial-gradient(ellipse 70% 55% at 18% 0%, rgba(255, 180, 160, 0.32), transparent 70%),
      linear-gradient(180deg, #fcd9b8 0%, #f8d1a8 22%, #f4e2cc 48%, #f5f1e9 78%);
  }
  /* 午后：金黄高光斑 + 浅暖左斑，底层暖金渐变 */
  #sky.afternoon {
    background:
      radial-gradient(ellipse 90% 70% at 72% 0%, rgba(255, 220, 160, 0.5), transparent 65%),
      radial-gradient(ellipse 70% 60% at 22% 0%, rgba(255, 210, 175, 0.32), transparent 70%),
      linear-gradient(180deg, #f6e8c7 0%, #f3e2bc 25%, #f5ecd6 55%, #f5f1e9 85%);
  }
  /* 黄昏：橙红日落光斑 + 紫粉补色，底层 5 段晕染 */
  #sky.dusk {
    background:
      radial-gradient(ellipse 90% 70% at 72% 0%, rgba(255, 175, 145, 0.55), transparent 65%),
      radial-gradient(ellipse 80% 60% at 22% 0%, rgba(210, 160, 180, 0.4), transparent 70%),
      linear-gradient(180deg, #e9b48c 0%, #e8a78a 20%, #d89a9a 40%, #c79aaa 62%, #a898b5 80%, #f5f1e9 100%);
  }
  /* 夜幕：右上一轮微月光晕 + 左上淡蓝霾，底层深蓝过渡 */
  #sky.night {
    background:
      radial-gradient(ellipse 60% 45% at 78% 8%, rgba(255, 240, 215, 0.18), transparent 60%),
      radial-gradient(ellipse 70% 55% at 18% 4%, rgba(180, 195, 220, 0.14), transparent 70%),
      linear-gradient(180deg, #242a3d 0%, #34374c 25%, #5a5266 50%, #9a8884 72%, #d4c5b8 88%, #f5f1e9 100%);
  }
  /* 深夜彩蛋：00-04 点星空色 + 细碎星点 */
  #sky.midnight {
    background:
      radial-gradient(1.5px 1.5px at 12% 18%, rgba(255, 255, 255, 0.9) 50%, transparent 51%),
      radial-gradient(1px 1px at 28% 42%, rgba(255, 255, 255, 0.75) 50%, transparent 51%),
      radial-gradient(1.5px 1.5px at 48% 22%, rgba(255, 255, 255, 0.85) 50%, transparent 51%),
      radial-gradient(1px 1px at 63% 12%, rgba(255, 255, 255, 0.7) 50%, transparent 51%),
      radial-gradient(1.5px 1.5px at 78% 36%, rgba(255, 255, 255, 0.9) 50%, transparent 51%),
      radial-gradient(1px 1px at 89% 18%, rgba(255, 255, 255, 0.75) 50%, transparent 51%),
      radial-gradient(1px 1px at 18% 55%, rgba(255, 255, 255, 0.6) 50%, transparent 51%),
      radial-gradient(1.5px 1.5px at 72% 52%, rgba(255, 255, 255, 0.8) 50%, transparent 51%),
      linear-gradient(180deg, #0c1230 0%, #1b1f45 22%, #2e2c58 44%, #58456a 64%, #8d6d7a 80%, #c4a798 90%, #f5f1e9 100%);
  }
  #sky.midnight::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 82% 14%, rgba(255, 248, 220, 0.95) 0%, rgba(255, 248, 220, 0.95) 2%, rgba(255, 248, 220, 0) 3.5%);
    pointer-events: none;
  }
</style>
