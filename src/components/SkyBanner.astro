---
/**
 * 顶部一笔天色 —— 纸本山水（Ink Wash Mountains）。
 *
 * 灵感：宋人山水（范宽 / 马远）/《富春山居图》/ 杉本博司《海景》。
 * 每段 sky 都嵌入同一道远山 SVG 轮廓（远 + 近双层 path），山色与天色随时段
 * 协同切换。中文随笔站独家方向。
 *
 * 不是 svelte 岛屿：之前 client:only="svelte" 在 mobile Chrome 出现 .sky
 * 宽度被 astro-island 包装元素限制（只渲染左半屏）。改用 Astro 组件 +
 * is:inline 脚本，div 在服务端就渲染，客户端只更新时段 class 与 fade-in。
 */
import { skyFromHour } from '~/lib/sky';

const initial = skyFromHour(new Date().getHours());
---

<div id="sky" class={`sky ${initial}`}>
  <svg class="mountains" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
    <path class="mtn-far" d="M0,72 L10,62 L22,68 L32,55 L46,64 L60,52 L72,62 L86,55 L100,66 L100,100 L0,100 Z"/>
    <path class="mtn-near" d="M0,82 L8,76 L18,80 L28,72 L42,80 L54,72 L68,82 L82,75 L100,82 L100,100 L0,100 Z"/>
  </svg>
</div>

<script is:inline>
  (function () {
    /* 与 src/lib/sky.ts skyFromHour 严格对齐：
       0-4 midnight / 5-10 morning / 11-16 afternoon / 17-19 dusk / 20-23 night */
    function mood(h) {
      if (h < 5) return 'midnight';
      if (h < 11) return 'morning';
      if (h < 17) return 'afternoon';
      if (h < 20) return 'dusk';
      return 'night';
    }
    var MOODS = ['midnight', 'night', 'morning', 'afternoon', 'dusk'];
    function apply() {
      var el = document.getElementById('sky');
      if (!el) return;
      var m = mood(new Date().getHours());
      MOODS.forEach(function (mm) {
        el.classList.remove(mm);
        if (document.body) document.body.classList.remove('mood-' + mm);
      });
      el.classList.add(m);
      /* 同步给 body 一份 mood class，让 topbar 文字按时段反白
         （midnight / night 暗色 sky 时文字 cosmic latte 米色，否则 ink 黑）。 */
      if (document.body) document.body.classList.add('mood-' + m);
    }
    function fadeIn() {
      var el = document.getElementById('sky');
      if (el) requestAnimationFrame(function () { el.classList.add('on'); });
    }
    apply();
    fadeIn();
    setInterval(apply, 60 * 1000);
    document.addEventListener('astro:page-load', function () {
      apply();
      fadeIn();
    });
  })();
</script>

<style is:global>
  /* 容器：sticky 顶部一线天（八大留白架构 R4，2026-04-27 锁定）。
     高度从原 280 缩到 240px ——「少天多纸」精神，但保留 R14 5 段山色 +
     R13 子时 8 颗 Cosmic Latte 星 + 满月 + 山墨黑全部意象。
     position: sticky 在 main flow 中钉住 viewport 顶 0..240，不再 fixed
     避免桌面端跨过 sidebar；卡片在 sky 之后的 .reading 流里滚动，
     z-index 10 让 sky 自然覆盖向上滚过的卡片。 */
  #sky {
    position: sticky;
    top: 0;
    height: 240px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.6s cubic-bezier(0.2, 0.6, 0.2, 1), background 0.8s ease;
    z-index: 10;
  }
  #sky.on { opacity: 1; }
  /* 底部柔和淡出到页面底色 ——「水岸」过渡 */
  #sky::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 64px;
    background: linear-gradient(to bottom, transparent, var(--bg-page));
    pointer-events: none;
    z-index: 2;
  }
  /* 远山 SVG：固定形状、占满 sky 容器，山色与浓淡走 CSS variable */
  #sky .mountains {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
  }
  #sky .mountains .mtn-far  { fill: var(--mtn-far,  #a8b4c0); opacity: var(--mtn-far-op,  0.32); }
  #sky .mountains .mtn-near { fill: var(--mtn-near, #7c8896); opacity: var(--mtn-near-op, 0.45); }

  /* ============================================================
     5 段时段：天色 + 山色 协同变化。
     - morning   雾里隐青：淡蓝灰天 + 远山若隐若现
     - afternoon 青翠分明：淡米青天 + 山轮廓清晰
     - dusk      逆光剪影：暖橙天 + 落日 + 山墨黑
     - night     山溶墨蓝：深蓝天 + 月在山上 + 散星
     - midnight  墨浓如黑：极深紫蓝天 + 满月 + 8 颗星（R13 彩蛋意象保留）
     ============================================================ */
  #sky.morning {
    --mtn-far:  #a8b4c0;
    --mtn-far-op:  0.32;
    --mtn-near: #7c8896;
    --mtn-near-op: 0.45;
    background: linear-gradient(180deg, #cfd2dd 0%, #e0d8d0 38%, #efe6dc 65%, #f5f1e9 92%);
  }
  #sky.afternoon {
    --mtn-far:  #9aa89a;
    --mtn-far-op:  0.45;
    --mtn-near: #5e6f5d;
    --mtn-near-op: 0.6;
    background: linear-gradient(180deg, #d8e1dc 0%, #e8e5d4 40%, #efece0 65%, #f5f1e9 92%);
  }
  #sky.dusk {
    --mtn-far:  #7a4030;
    --mtn-far-op:  0.55;
    --mtn-near: #3a2018;
    --mtn-near-op: 0.78;
    background:
      radial-gradient(circle 32px at 75% 72px, rgba(220, 135, 85, 0.65), transparent 70%),
      linear-gradient(180deg, #e8b890 0%, #d8a4a0 30%, #e0c8c0 60%, #f5f1e9 92%);
  }
  #sky.night {
    --mtn-far:  #1c2438;
    --mtn-far-op:  0.7;
    --mtn-near: #0c1024;
    --mtn-near-op: 0.88;
    background:
      radial-gradient(circle 12px at 25% 28px, rgba(245, 235, 210, 0.92) 60%, rgba(245, 235, 210, 0) 80%),
      radial-gradient(circle 28px at 25% 28px, rgba(245, 235, 210, 0.18), transparent 70%),
      radial-gradient(1px 1px at 50% 20%, rgba(255, 255, 255, 0.4) 50%, transparent 51%),
      radial-gradient(1px 1px at 70% 38%, rgba(255, 255, 255, 0.45) 50%, transparent 51%),
      linear-gradient(180deg, #2a3148 0%, #545068 35%, #c8b9b3 78%, #f5f1e9 100%);
  }
  /* 深夜彩蛋（R13 锁定）：满月 + 8 颗星点 + 极深紫蓝 + 山墨浓如黑
     星点用 Cosmic Latte #FFF8E7 = rgb(255,248,231)，是 2003 年 Glazebrook & Baldry
     用 2dF 巡天 20 万星系算出的宇宙平均色。月色 rgb(255,250,225) 不动。
     每颗星的 radial-gradient：硬核心 (0-22% 实色) + 软光晕 (22-78% 衰减)，
     这样在 #36325c 中天色上才看得见；纯 2.5px size + 40% stop 等于把核心做没。 */
  #sky.midnight {
    --mtn-far:  #0a0e22;
    --mtn-far-op:  0.82;
    --mtn-near: #040614;
    --mtn-near-op: 0.95;
    background:
      radial-gradient(circle 14px at 75% 36px, rgba(255, 250, 225, 0.95) 60%, rgba(255, 250, 225, 0) 85%),
      radial-gradient(circle 40px at 75% 36px, rgba(255, 250, 225, 0.18), transparent 70%),
      radial-gradient(circle 5.5px at 14% 18%, rgba(255, 248, 231, 1) 0%, rgba(255, 248, 231, 1) 22%, rgba(255, 248, 231, 0.42) 48%, rgba(255, 248, 231, 0.08) 78%, transparent 100%),
      radial-gradient(circle 4px   at 30% 32%, rgba(255, 248, 231, 1) 0%, rgba(255, 248, 231, 0.95) 22%, rgba(255, 248, 231, 0.32) 48%, rgba(255, 248, 231, 0.06) 78%, transparent 100%),
      radial-gradient(circle 5px   at 48% 18%, rgba(255, 248, 231, 1) 0%, rgba(255, 248, 231, 1) 22%, rgba(255, 248, 231, 0.4)  48%, rgba(255, 248, 231, 0.08) 78%, transparent 100%),
      radial-gradient(circle 4.5px at 60% 38%, rgba(255, 248, 231, 1) 0%, rgba(255, 248, 231, 0.92) 22%, rgba(255, 248, 231, 0.28) 48%, rgba(255, 248, 231, 0.06) 78%, transparent 100%),
      radial-gradient(circle 5px   at 88% 14%, rgba(255, 248, 231, 1) 0%, rgba(255, 248, 231, 0.95) 22%, rgba(255, 248, 231, 0.32) 48%, rgba(255, 248, 231, 0.06) 78%, transparent 100%),
      radial-gradient(circle 5.5px at 22% 50%, rgba(255, 248, 231, 1) 0%, rgba(255, 248, 231, 0.85) 22%, rgba(255, 248, 231, 0.25) 48%, rgba(255, 248, 231, 0.05) 78%, transparent 100%),
      radial-gradient(circle 4px   at 42% 56%, rgba(255, 248, 231, 1) 0%, rgba(255, 248, 231, 0.78) 22%, rgba(255, 248, 231, 0.22) 48%, rgba(255, 248, 231, 0.05) 78%, transparent 100%),
      radial-gradient(circle 4.5px at 70% 60%, rgba(255, 248, 231, 1) 0%, rgba(255, 248, 231, 0.7)  22%, rgba(255, 248, 231, 0.2)  48%, rgba(255, 248, 231, 0.04) 78%, transparent 100%),
      linear-gradient(180deg, #0c1230 0%, #1a2150 28%, #36325c 58%, #6c5876 78%, #a8908a 92%, #f5f1e9 100%);
  }
</style>
