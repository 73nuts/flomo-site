---
/**
 * 顶部一笔天色。根据访问时设备本地小时切换 morning / afternoon / dusk / night。
 *
 * 为什么不是 svelte 岛屿：
 *   之前用 <SkyBanner client:only="svelte" /> 在 mobile Chrome 下出现了 .sky 宽度
 *   被 astro-island 包装元素限制的 bug（只渲染左半屏，右侧留白）。
 *   改用 Astro 组件 + is:inline 脚本：div 在服务端就渲染，
 *   客户端只负责根据当前时间更新 class，定位不受任何包装层影响。
 */
import { skyFromHour } from '~/lib/sky';

// 服务端静态渲染取不到访客的时间；先用 afternoon 兜底，客户端立即覆盖。
const initial = skyFromHour(new Date().getHours());
---

<div id="sky" class={`sky ${initial}`}></div>

<script is:inline>
  (function () {
    /* 与 src/lib/sky.ts skyFromHour 严格对齐：
       0-4 midnight / 5-10 morning / 11-16 afternoon / 17-19 dusk / 20-23 night */
    function mood(h) {
      if (h < 5) return 'midnight';
      if (h < 11) return 'morning';
      if (h < 17) return 'afternoon';
      if (h < 20) return 'dusk';
      return 'night';
    }
    var MOODS = ['midnight', 'night', 'morning', 'afternoon', 'dusk'];
    function apply() {
      var el = document.getElementById('sky');
      if (!el) return;
      // 用 classList 增删而非整段重写，避免吞掉 .on（fadeIn 类）导致每分钟闪一次
      MOODS.forEach(function (m) { el.classList.remove(m); });
      el.classList.add(mood(new Date().getHours()));
    }
    function fadeIn() {
      var el = document.getElementById('sky');
      if (el) requestAnimationFrame(function () { el.classList.add('on'); });
    }
    apply();
    fadeIn();
    setInterval(apply, 60 * 1000);
    // Astro 视图过渡切页后重新挂元素，需要再 apply 一次
    document.addEventListener('astro:page-load', function () { apply(); fadeIn(); });
  })();
</script>

<style is:global>
  /* sky = "晨光透窗"。来自 v2-good-taste 设计稿 mobile-delights 的 radial 双光斑构造：
     时段配色（linear gradient 底层）保留原稿 4 段高饱和色相 + 顶部叠两团光斑，
     让纯色带升级为"有方向的光"。opacity 0→1 淡入也来自原稿 .sky.on 切换。 */
  #sky {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 260px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.6s cubic-bezier(0.2, 0.6, 0.2, 1), background 0.8s ease;
    z-index: 0;
  }
  #sky.on { opacity: 1; }
  /* 底部柔和淡出到页面底色，让 sky 和内容无缝衔接 */
  #sky::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 110px;
    background: linear-gradient(to bottom, transparent, var(--bg-page));
    pointer-events: none;
  }
  /* 4 段统一原则：
     · linear 走单色相系（同色相内由深→浅），不跨色相 → 不出 banding
     · stop 间距均匀（25/25/25），避免局部密集堆叠
     · radial 双光斑 transparent 80%，与 linear stop 错峰，过渡边界不重合
     · 暖色集中顶部，最末段过渡到 body bg #f5f1e9 */
  /* 晨光：清冷蓝紫余韵（夜未褪尽）+ 桃粉初阳 → 米白。
     与 afternoon 拉开区分度的关键：顶部留一抹冷调蓝紫 #cfc7d8，初阳是桃粉 #ebcab8，
     不和午后的纯金黄混淆。 */
  #sky.morning {
    background:
      radial-gradient(ellipse 90% 70% at 70% 0%, rgba(255, 200, 145, 0.55), transparent 78%),
      radial-gradient(ellipse 70% 55% at 18% 4%, rgba(180, 165, 200, 0.4), transparent 80%),
      linear-gradient(180deg, #cfc7d8 0%, #ebcab8 22%, #f4d9c4 48%, #f5e8db 72%, #f5f1e9 94%);
  }
  /* 午后：明亮金黄、高饱和阳光感。比 morning 更黄、更亮、更"烈"。 */
  #sky.afternoon {
    background:
      radial-gradient(ellipse 95% 72% at 72% 0%, rgba(255, 215, 130, 0.7), transparent 78%),
      radial-gradient(ellipse 70% 60% at 22% 0%, rgba(255, 200, 150, 0.45), transparent 80%),
      linear-gradient(180deg, #f5d68a 0%, #f4cd80 22%, #f6daa4 48%, #f3e6c8 72%, #f5f1e9 94%);
  }
  #sky.dusk {
    background:
      radial-gradient(ellipse 90% 70% at 72% 0%, rgba(255, 175, 145, 0.6), transparent 80%),
      radial-gradient(ellipse 80% 60% at 22% 0%, rgba(220, 170, 180, 0.4), transparent 80%),
      linear-gradient(180deg, #e9b48c 0%, #e2a89a 25%, #d8b4ad 50%, #ecdfd6 75%, #f5f1e9 95%);
  }
  /* 夜幕：5 段缩为 4 段，去掉中间冷紫 #6b6076 / 暖灰 #a89690 的色相急转。
     蓝灰系单色相内深→浅过渡：深蓝 → 蓝紫灰 → 灰米 → 米白。 */
  #sky.night {
    background:
      radial-gradient(ellipse 60% 45% at 78% 8%, rgba(255, 240, 215, 0.22), transparent 80%),
      radial-gradient(ellipse 70% 55% at 18% 4%, rgba(180, 195, 220, 0.18), transparent 80%),
      linear-gradient(180deg, #2a3148 0%, #4f4c66 28%, #8f8294 55%, #c8b9b3 80%, #f5f1e9 100%);
  }
  /* 深夜彩蛋：00-04 点星空色 + 细碎星点 */
  #sky.midnight {
    background:
      radial-gradient(1.5px 1.5px at 12% 18%, rgba(255, 255, 255, 0.9) 50%, transparent 51%),
      radial-gradient(1px 1px at 28% 42%, rgba(255, 255, 255, 0.75) 50%, transparent 51%),
      radial-gradient(1.5px 1.5px at 48% 22%, rgba(255, 255, 255, 0.85) 50%, transparent 51%),
      radial-gradient(1px 1px at 63% 12%, rgba(255, 255, 255, 0.7) 50%, transparent 51%),
      radial-gradient(1.5px 1.5px at 78% 36%, rgba(255, 255, 255, 0.9) 50%, transparent 51%),
      radial-gradient(1px 1px at 89% 18%, rgba(255, 255, 255, 0.75) 50%, transparent 51%),
      radial-gradient(1px 1px at 18% 55%, rgba(255, 255, 255, 0.6) 50%, transparent 51%),
      radial-gradient(1.5px 1.5px at 72% 52%, rgba(255, 255, 255, 0.8) 50%, transparent 51%),
      /* 7 段缩为 6 段，stop 间距均匀（0/25/50/70/85/100），
         去掉 80-90% 三站挤一起的陡过渡，深蓝→紫灰→暖米→米白线性过渡更自然 */
      linear-gradient(180deg, #0c1230 0%, #1a2150 25%, #36325c 50%, #6c5876 70%, #a8908a 85%, #f5f1e9 100%);
  }
  #sky.midnight::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 82% 14%, rgba(255, 248, 220, 0.95) 0%, rgba(255, 248, 220, 0.95) 2%, rgba(255, 248, 220, 0) 3.5%);
    pointer-events: none;
  }
</style>
